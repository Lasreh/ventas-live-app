<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:padding="16dp">

    <!-- HEADER -->
    <TextView
        android:text="📊 Clientes"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"/>

    <!-- SUBTÍTULO -->
    <TextView
        android:text="Resumen de compras y total gastado"
        android:textSize="14sp"
        android:textColor="#64748B"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>

    <!-- 📅 FILTRO FECHA -->
    <Button
        android:id="@+id/btnFechaClientes"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Filtrar por fecha"
        android:textColor="#FFFFFF"
        android:backgroundTint="#111827"
        android:layout_marginBottom="12dp"/>

    <!-- 💰 TOTAL GENERAL -->
    <TextView
        android:id="@+id/txtTotalGeneral"
        android:text="Total general: $0"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2563EB"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>

    <!-- LISTA -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerClientes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="12dp"/>

</LinearLayout>