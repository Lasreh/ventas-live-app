<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nueva venta"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:gravity="center"
            android:layout_marginBottom="18dp"/>

        <!-- CARD CONTENEDOR -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- NOMBRE -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="#2563EB"
                    app:hintTextColor="#64748B">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre de la prenda"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- PRECIO -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="#2563EB">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPrecio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Precio"
                        android:inputType="number"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- CLIENTE -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="#2563EB">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editCliente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Cliente"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- BOTÓN -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGuardar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Guardar venta"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:layout_marginTop="20dp"
                    app:cornerRadius="14dp"
                    app:backgroundTint="#2563EB"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>